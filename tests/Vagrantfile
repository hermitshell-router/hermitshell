# -*- mode: ruby -*-
DISTRO_BOXES = {
  "debian12"    => "generic/debian12",
  "ubuntu2404"  => "bento/ubuntu-24.04",
  # ubuntu2204 boxes don't boot under qemu emulation (no KVM);
  # install.sh still supports 22.04 on real hardware
}

distro = ENV['HERMIT_DISTRO'] || 'debian12'
router_box = DISTRO_BOXES.fetch(distro) {
  abort "Unknown distro '#{distro}'. Valid: #{DISTRO_BOXES.keys.join(', ')}"
}

Vagrant.configure("2") do |config|
  config.vm.provider :libvirt do |libvirt|
    libvirt.memory = 512
    libvirt.cpus = 1
  end

  # WAN VM - fake ISP (always Debian 12)
  config.vm.define "wan" do |wan|
    wan.vm.box = "generic/debian12"
    wan.vm.hostname = "wan"
    wan.vm.network :private_network,
      libvirt__network_name: "hermit-wan",
      libvirt__dhcp_enabled: false,
      libvirt__forward_mode: "none",
      ip: "192.168.100.2"
    wan.vm.provision "shell", path: "provision/wan.sh"
  end

  # Router VM - runs HermitShell (distro-selectable)
  config.vm.define "router" do |router|
    router.vm.box = router_box
    router.vm.hostname = "router"
    router.vm.synced_folder "../target/release", "/opt/hermitshell", type: "rsync", create: true
    # WAN interface
    router.vm.network :private_network,
      libvirt__network_name: "hermit-wan",
      libvirt__dhcp_enabled: false,
      libvirt__forward_mode: "none",
      auto_config: false
    # LAN interface (auto_config: false, provision script sets /16 netmask)
    router.vm.network :private_network,
      libvirt__network_name: "hermit-lan",
      libvirt__dhcp_enabled: false,
      libvirt__forward_mode: "none",
      auto_config: false
    router.vm.provision "shell", path: "provision/router.sh"
  end

  # LAN VM - test client (always Debian 12)
  config.vm.define "lan" do |lan|
    lan.vm.box = "generic/debian12"
    lan.vm.hostname = "lan"
    lan.vm.network :private_network,
      libvirt__network_name: "hermit-lan",
      libvirt__dhcp_enabled: false,
      libvirt__forward_mode: "none",
      auto_config: false
    lan.vm.provision "shell", path: "provision/lan.sh"
  end
end
